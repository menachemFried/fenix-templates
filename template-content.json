{
    "id": "cmake-clang-lldb-template",
    "name": "C++ CMake & Clang Project (Auto-Debug)",
    "description": "פרויקט תשתיתי המקים מערכת C++ המבוססת על CMake, קימפול Clang, השלמת קוד שקופה דרך clangd וניפוי שגיאות באמצעות CodeLLDB.",
    "author": "Menachem Fried",
    "version": "1.0.0",
    "directories": [
        "UserApp",
        "UserApp/Src",
        "UserApp/Inc",
        "build",
        ".vscode"
    ],
    "files": {
        "download": [
            {
                "from": "template-files/CMakeLists.txt",
                "to": "CMakeLists.txt"
            },
            {
                "from": "template-files/UserApp/Inc/hello.hpp",
                "to": "UserApp/Inc/hello.hpp"
            },
            {
                "from": "template-files/UserApp/Src/main.cpp",
                "to": "UserApp/Src/main.cpp"
            },
            {
                "from": "template-files/.vscode/settings.json",
                "to": ".vscode/settings.json"
            },
            {
                "from": "template-files/.vscode/tasks.json",
                "to": ".vscode/tasks.json"
            },
            {
                "from": "template-files/.vscode/launch.json",
                "to": ".vscode/launch.json"
            }
        ],
        "open": [
            "UserApp/Src/main.cpp"
        ]
    },
    "postRunCommands": [
        "cmake -S . -B build -DCMAKE_CXX_COMPILER=clang++"
    ]
}